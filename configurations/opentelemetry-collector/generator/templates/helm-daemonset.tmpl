{{- set . "K8s" true }}
{{- set . "Container" true }}
{{- if .Preamble -}}
# Recommended values.yaml for the OpenTelemetry Collector Helm Chart
{{include "setup" .}}
# Required secrets: datadog-secrets::api-key
# Remember to modify DD_SITE if not using datadoghq.com
{{- set . "Preamble" false}}
{{- end}}

extraEnvs:
  - name: DD_SITE
    value: datadoghq.com # Update if necessary
  - name: DD_API_KEY
    valueFrom:
      secretKeyRef:
        name: datadog-secrets
        key: api-key
  {{- if eq .CloudEnvironment ""}}
  # Use the K8s-related variables predefined by the Helm chart
  - name: OTEL_RESOURCE_ATTRIBUTES
    value: "k8s.node.name=$(OTEL_K8S_NODE_NAME)"
  {{- end}}
{{- if .KubeletStats}}
  - name: K8S_NODE_NAME
    valueFrom:
      fieldRef:
        fieldPath: spec.nodeName
{{- end}}

mode: daemonset
image:
  repository: otel/opentelemetry-collector-contrib
  tag: {{.OtelcolVersion}}
command:
  name: "otelcol-contrib"
  extraArgs: ["--feature-gates", "+connector.spanmetrics.includeCollectorInstanceID"]

# Service account for the k8s_attributes processor
serviceAccount:
  create: true
clusterRole:
  create: true
  rules:
    - apiGroups: [""]
      resources: ["pods", "namespaces"{{- if .KubeletStats}}, "nodes", "nodes/stats"{{- end}}]
      verbs: ["get", "watch", "list"]
    - apiGroups: ["apps"]
      resources: ["replicasets"]
      verbs: ["get", "list", "watch"]
    - apiGroups: ["extensions"]
      resources: ["replicasets"]
      verbs: ["get", "list", "watch"]

# Volume mount for the host metrics receiver
extraVolumes:
  - name: hostfs
    hostPath:
      path: /
extraVolumeMounts:
  - name: hostfs
    mountPath: /hostfs
    readOnly: true
    mountPropagation: HostToContainer

# Some components take a long time to start, so set a startup probe
startupProbe:
  initialDelaySeconds: 1
  periodSeconds: 2
  failureThreshold: 20 # 40 seconds
  httpGet:
    port: 13133
    path: /

alternateConfig:
  {{ include "otelcol-agent" . | indent 2 }}
